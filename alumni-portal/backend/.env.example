# Database Configuration
# Use DATABASE_URL for a single connection string (e.g., MySQL, Postgres)
# DATABASE_URL=mysql+pymysql://user:password@host:port/dbname
DATABASE_URL=

# OR individual variables
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=alumni_portal_db

# Security
JWT_SECRET_KEY=yoursupersecretkeyhere

# CORS
# Comma-separated list of allowed origins (e.g., https://yourfrontend.vercel.app)
ALLOWED_ORIGINS=*

# Production Server Port
PORT=5000
